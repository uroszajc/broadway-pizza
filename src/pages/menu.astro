---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Menu" description="Broadway Pizza menu — classic pizzas, premium, Sicilian, sides, and more. Since 1969.">
  <section class="page-header">
    <div class="container">
      <h1>Our Menu</h1>
      <p>Wood-fired style pizzas made fresh to order. Open 4pm daily.</p>
    </div>
  </section>

  <section class="menu-section">
    <div class="container">
      <h2>🍕 Classic Pizzas</h2>
      <p class="section-note">All pizzas available in Small (9"), Medium (11"), Large (14") and Family (16") sizes</p>
      <div class="menu-grid">

        <div class="menu-item">
          <div class="item-header">
            <h3>Margherita</h3>
            <span class="price">$10.90 – $21.90</span>
          </div>
          <p>Tomato base, mozzarella, fresh basil</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Hawaiian</h3>
            <span class="price">$11.90 – $23.90</span>
          </div>
          <p>Ham, pineapple, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>BBQ Chicken</h3>
            <span class="price">$14.90 – $27.90</span>
          </div>
          <p>Chicken, onion, mushroom, BBQ sauce</p>
          <span class="badge-popular">🔥 Popular</span>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Beef & Onion</h3>
            <span class="price">$12.90 – $25.90</span>
          </div>
          <p>Beef, onion, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Pepperoni</h3>
            <span class="price">$12.90 – $25.90</span>
          </div>
          <p>Pepperoni, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Canadian</h3>
            <span class="price">$12.90 – $25.90</span>
          </div>
          <p>Ham, bacon, pineapple, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Supreme</h3>
            <span class="price">$15.90 – $29.90</span>
          </div>
          <p>Ham, pepperoni, sausage, mushroom, onion, capsicum, olive, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Vegetarian</h3>
            <span class="price">$13.90 – $27.90</span>
          </div>
          <p>Mushroom, onion, capsicum, tomato, olive, mozzarella</p>
        </div>

      </div>
    </div>
  </section>

  <section class="menu-section alt">
    <div class="container">
      <h2>🔥 Premium Pizzas</h2>
      <div class="menu-grid">

        <div class="menu-item">
          <div class="item-header">
            <h3>The Works</h3>
            <span class="price">$14.90 – $27.90</span>
          </div>
          <p>Chicken, onion, mushroom, BBQ sauce</p>
          <span class="badge-popular">🔥 Best Seller</span>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Mexicana</h3>
            <span class="price">$14.90 – $27.90</span>
          </div>
          <p>Beef, onion, capsicum, chilli, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Aussie</h3>
            <span class="price">$13.90 – $26.90</span>
          </div>
          <p>Ham, bacon, egg, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>BBQ Ribs</h3>
            <span class="price">$15.90 – $29.90</span>
          </div>
          <p>Pork ribs, onion, mushroom, BBQ sauce</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Tandoori Chicken</h3>
            <span class="price">$15.90 – $29.90</span>
          </div>
          <p>Tandoori chicken, onion, capsicum, mozzarella, garlic sauce</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Mediterranean</h3>
            <span class="price">$15.90 – $29.90</span>
          </div>
          <p>Feta, tomato, capsicum, onion, olive, mozzarella</p>
        </div>

      </div>
    </div>
  </section>

  <section class="menu-section">
    <div class="container">
      <h2>🥩 Sicilian Pizzas</h2>
      <div class="menu-grid">

        <div class="menu-item">
          <div class="item-header">
            <h3>Sicilian Meatlovers</h3>
            <span class="price">$13.90 – $29.90</span>
          </div>
          <p>Ham, pepperoni, beef, bacon, BBQ sauce</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Sicilian Capricciosa</h3>
            <span class="price">$14.90 – $29.90</span>
          </div>
          <p>Ham, mushroom, artichoke, olive, mozzarella</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Sicilian Napolitano</h3>
            <span class="price">$13.90 – $26.90</span>
          </div>
          <p>Anchovies, onion, capers, olive, mozzarella</p>
        </div>

      </div>
    </div>
  </section>

  <section class="menu-section alt">
    <div class="container">
      <h2>🍟 Sides & Extras</h2>
      <div class="menu-grid">

        <div class="menu-item">
          <div class="item-header">
            <h3>Italian Meatballs</h3>
            <span class="price">$11.90</span>
          </div>
          <p>Four huge meatballs in original Broadway sauce, topped with mozzarella, served with cheese bread</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Cheese Garlic Bread</h3>
            <span class="price">$6.90</span>
          </div>
          <p>Four pieces of garlic bread loaded with melted cheese</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Garlic Bread</h3>
            <span class="price">$4.90</span>
          </div>
          <p>Four pieces of fresh baked garlic bread</p>
        </div>

        <div class="menu-item">
          <div class="item-header">
            <h3>Chips</h3>
            <span class="price">$5.90</span>
          </div>
          <p>Seasoned hot chips</p>
        </div>

      </div>
    </div>
  </section>

  <section class="call-to-order">
    <div class="container">
      <h2>Ready to order?</h2>
      <p>Call us directly — we don't currently take online orders, but we're always ready to take your call.</p>
      <div class="order-actions">
        <a href="tel:0893898500" class="btn btn-large">📞 (08) 9389 8500</a>
        <a href="/contact" class="btn-outline btn">Get Directions →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.page-header { background: var(--warm); padding: 3rem 0 2.5rem; text-align: center; }
.page-header h1 { font-size: 3rem; color: white; margin-bottom: 0.5rem; }
.page-header p { color: rgba(255,255,255,0.85); }
.container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

.menu-section { padding: 4rem 0; }
.menu-section.alt { background: var(--cream); }
.menu-section h2 { font-size: 1.8rem; margin-bottom: 2rem; color: var(--charcoal); }
.section-note { font-size: 0.85rem; color: var(--text-light); margin-bottom: 2rem; }

.menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.2rem; }
.menu-item { background: white; border-radius: 10px; padding: 1.5rem; border: 1px solid var(--border); position: relative; transition: box-shadow 0.2s; }
.menu-item:hover { box-shadow: var(--shadow); }
.menu-item h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--charcoal); margin-bottom: 0.3rem; }
.menu-item p { font-size: 0.82rem; color: var(--text-light); line-height: 1.6; }
.item-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; gap: 1rem; }
.price { font-weight: 700; color: var(--warm); white-space: nowrap; }
.badge-popular { display: inline-block; background: rgba(200,70,48,0.1); color: var(--warm); font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 3px; margin-top: 0.5rem; text-transform: uppercase; letter-spacing: 0.08em; }

.call-to-order { padding: 4rem 0; text-align: center; background: var(--charcoal); color: white; }
.call-to-order h2 { font-size: 2rem; color: white; margin-bottom: 0.8rem; }
.call-to-order p { color: rgba(255,255,255,0.7); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto; }
.order-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-large { padding: 1rem 2.5rem; font-size: 1.1rem; }
.btn-outline.btn { border-color: white; color: white; }
.btn-outline.btn:hover { background: white; color: var(--charcoal); }
</style>